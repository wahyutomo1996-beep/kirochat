generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  username            String         @unique
  password            String
  role                String         @default("user")
  status              String         @default("pending")
  // SECURITY: We store the SHA-256 hash of the API key, never the plain key.
  // Plain key is only shown to the user once at creation/regeneration.
  apiKeyHash          String?        @unique
  /// Forces password change on next login (used for default admin seed).
  mustChangePassword  Boolean        @default(false)
  /// Per-workspace user preferences serialized as JSON, e.g.
  /// {"coding":{"bridgeImages":true},"trading":{"bridgeImages":true}}
  /// Default empty {} means workspace-level defaults from src/lib/workspaces.ts apply.
  workspaceSettings   String         @default("{}")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  providers           Provider[]
  conversations       Conversation[]
  usages              Usage[]
  kiroAccounts        KiroAccount[]
  combos              Combo[]
  telegramBot         TelegramBot?
}

model Provider {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  baseUrl     String
  apiKey      String
  models      String   @default("[]")
  modelsLastFetched DateTime?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  /// When true, this provider's `sharedModels` are visible + dispatchable
  /// to ALL approved users (not just `userId`). The owner's apiKey is
  /// used for upstream auth, so the owner pays for any quota burned by
  /// other users.
  ///
  /// Use case: admin shares the free tier of an external provider
  /// (e.g. Genfity's gpt-5.5:free + claude-opus-4.6:free) with all
  /// registered users, no per-user signup required. Paid models stay
  /// private to the owner.
  isShared    Boolean  @default(false)
  /// JSON-encoded array of model ids that the share applies to.
  /// Empty array = nothing is shared (effective NOT shared even if
  /// isShared=true). When non-empty + isShared=true, only these models
  /// appear in other users' provider catalog. The owner still sees
  /// the full `models` list.
  sharedModels String  @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages      Usage[]

  @@index([userId])
  @@index([isShared])
}

model KiroAccount {
  id                    String    @id @default(cuid())
  userId                String
  refreshToken          String
  accessToken           String?
  tokenExpiresAt        DateTime?
  email                 String?
  status                String    @default("active")
  usageCount            Int       @default(0)
  totalPromptTokens     Int       @default(0)
  totalCompletionTokens Int       @default(0)
  totalTokens           Int       @default(0)
  totalRequests         Int       @default(0)
  failedRequests        Int       @default(0)
  /// Optional per-account daily request limit. NULL means unlimited
  /// (free tier — uses Kiros server-side rate limits as the only ceiling).
  /// When set, the UI shows "X / Y requests left today" and warns at 80%.
  /// We dont enforce this server-side as a hard block; its an
  /// observability + planning tool. Marking exhausted still happens via
  /// real Kiro rate-limit responses.
  dailyLimit            Int?
  /// When the current quota period ends and counter resets.
  /// Null = no scheduled reset (auto-derived as next UTC midnight when
  /// first request of period happens, depending on quotaCycle).
  /// Used by Quota Tracker page to display "Resets in 5h 22m".
  quotaResetAt          DateTime?
  /// Reset cycle: 'daily' (default) | 'weekly' | 'monthly' | 'custom'.
  /// Affects how we auto-advance quotaResetAt at rollover.
  quotaCycle            String    @default("daily")
  lastUsed              DateTime?
  lastError             String?
  lastErrorAt           DateTime?
  exhaustedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages                Usage[]

  @@index([userId, status])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  model     String    @default("")
  provider  String    @default("")
  /// Logical workspace this conversation belongs to.
  /// One of: "general", "coding", "trading" (extensible).
  /// Used to filter Recent in the sidebar so each workspace's history
  /// stays separate without forcing the user to rename or tag manually.
  workspace String    @default("general")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, workspace, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  images         String       @default("[]")
  model          String       @default("")
  promptTokens   Int          @default(0)
  completionTokens Int        @default(0)
  totalTokens    Int          @default(0)
  latencyMs      Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Usage {
  id               String    @id @default(cuid())
  userId           String
  providerId       String?
  providerName     String
  kiroAccountId    String?
  model            String
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  latencyMs        Int       @default(0)
  cost             Float     @default(0)
  success          Boolean   @default(true)
  errorMessage     String?
  createdAt        DateTime  @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         Provider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  kiroAccount      KiroAccount? @relation(fields: [kiroAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([providerId, createdAt])
  @@index([kiroAccountId, createdAt])
  @@index([model, createdAt])
}

/// User-defined model combo. A combo is an ordered chain of (provider, model)
/// steps tried sequentially - if the first step fails (rate limit, auth,
/// network), the dispatcher falls back to the next. Used for things like
/// "coding-premium" (Claude Opus -> GPT-4o -> Kiro Sonnet free) or
/// "trading-realtime" (Groq fast model -> Gemini Flash -> Kiro Haiku).
model Combo {
  id          String   @id @default(cuid())
  userId      String
  /// Slug used in chat dropdown, e.g. "coding-premium". Lowercase, hyphenated.
  slug        String
  name        String
  description String   @default("")
  /// One of: coding, trading, research, general, custom
  category    String   @default("custom")
  /// Emoji icon shown in UI
  icon        String   @default("\u26A1")
  /// JSON-encoded array of ComboStep:
  ///   [{providerId, model, label?}, ...]
  /// providerId can be the special value "__prometheus__" for the built-in pool.
  steps       String   @default("[]")
  /// Auto-route enabled in chat (shown in dropdown alongside individual models)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
}

/// Telegram bot integration. One bot per user. The bot accepts messages
/// from a whitelisted set of Telegram user IDs and proxies them through
/// the user's existing Kiro pool / chat dispatch infrastructure.
///
/// Auth model: Telegram -> our server uses URL-embedded webhook secret
/// (random 32-byte hex) so anyone with the URL can post (Telegram needs
/// it). Plus we verify `from.id` is in `allowedUserIds` before processing.
///
/// The bot token is encrypted at rest with the same key used for Kiro
/// refresh tokens (lib/encryption). Plain token never leaves Settings UI.
model TelegramBot {
  id              String   @id @default(cuid())
  userId          String   @unique
  /// Encrypted bot token (e.g. "1234:ABCdef..."). Never returned plaintext.
  token           String
  /// Bot's Telegram username (without @), captured from getMe at save time.
  /// Cached for display; not used for auth.
  botUsername     String?
  /// Comma-separated whitelist of Telegram user IDs (numbers as strings).
  /// e.g. "123456789,987654321". Empty = locked (no one can use the bot).
  allowedUserIds  String   @default("")
  /// Random 32-byte hex secret embedded in the webhook URL. We rotate this
  /// when the user re-saves config so leaked URLs become inert.
  webhookSecret   String   @unique
  /// Default workspace selection passed to the chat dispatcher when a
  /// Telegram user sends a message. JSON: { mode: 'combo'|'model', value: string }.
  /// Empty string = use general workspace's default fallback.
  defaultSelection String  @default("")
  /// True when last setWebhook call to Telegram succeeded.
  webhookActive   Boolean  @default(false)
  /// Last error from Telegram API (set + register webhook + sendMessage).
  /// Surfaced in Settings UI so user can debug rejected tokens.
  lastError       String?
  lastErrorAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
