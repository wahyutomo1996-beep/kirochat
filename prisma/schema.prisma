generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  username            String         @unique
  password            String
  role                String         @default("user")
  status              String         @default("pending")
  // SECURITY: We store the SHA-256 hash of the API key, never the plain key.
  // Plain key is only shown to the user once at creation/regeneration.
  apiKeyHash          String?        @unique
  /// Forces password change on next login (used for default admin seed).
  mustChangePassword  Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  providers           Provider[]
  conversations       Conversation[]
  usages              Usage[]
  kiroAccounts        KiroAccount[]
  combos              Combo[]
}

model Provider {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  baseUrl     String
  apiKey      String
  models      String   @default("[]")
  modelsLastFetched DateTime?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages      Usage[]

  @@index([userId])
}

model KiroAccount {
  id                    String    @id @default(cuid())
  userId                String
  refreshToken          String
  accessToken           String?
  tokenExpiresAt        DateTime?
  email                 String?
  status                String    @default("active")
  usageCount            Int       @default(0)
  totalPromptTokens     Int       @default(0)
  totalCompletionTokens Int       @default(0)
  totalTokens           Int       @default(0)
  totalRequests         Int       @default(0)
  failedRequests        Int       @default(0)
  lastUsed              DateTime?
  lastError             String?
  lastErrorAt           DateTime?
  exhaustedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages                Usage[]

  @@index([userId, status])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  model     String    @default("")
  provider  String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  images         String       @default("[]")
  model          String       @default("")
  promptTokens   Int          @default(0)
  completionTokens Int        @default(0)
  totalTokens    Int          @default(0)
  latencyMs      Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Usage {
  id               String    @id @default(cuid())
  userId           String
  providerId       String?
  providerName     String
  kiroAccountId    String?
  model            String
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  latencyMs        Int       @default(0)
  cost             Float     @default(0)
  success          Boolean   @default(true)
  errorMessage     String?
  createdAt        DateTime  @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         Provider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  kiroAccount      KiroAccount? @relation(fields: [kiroAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([providerId, createdAt])
  @@index([kiroAccountId, createdAt])
  @@index([model, createdAt])
}

/// User-defined model combo. A combo is an ordered chain of (provider, model)
/// steps tried sequentially - if the first step fails (rate limit, auth,
/// network), the dispatcher falls back to the next. Used for things like
/// "coding-premium" (Claude Opus -> GPT-4o -> Kiro Sonnet free) or
/// "trading-realtime" (Groq fast model -> Gemini Flash -> Kiro Haiku).
model Combo {
  id          String   @id @default(cuid())
  userId      String
  /// Slug used in chat dropdown, e.g. "coding-premium". Lowercase, hyphenated.
  slug        String
  name        String
  description String   @default("")
  /// One of: coding, trading, research, general, custom
  category    String   @default("custom")
  /// Emoji icon shown in UI
  icon        String   @default("\u26A1")
  /// JSON-encoded array of ComboStep:
  ///   [{providerId, model, label?}, ...]
  /// providerId can be the special value "__prometheus__" for the built-in pool.
  steps       String   @default("[]")
  /// Auto-route enabled in chat (shown in dropdown alongside individual models)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
}
