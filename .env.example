# =====================================================
# Database
# =====================================================
DATABASE_URL="file:./dev.db"

# =====================================================
# Security - MUST be changed in production
# =====================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="change-this-32-char-key-for-prod!"

# =====================================================
# App branding
# =====================================================
NEXT_PUBLIC_APP_NAME="Prometheus"

# =====================================================
# RTK Query base URL
# Empty = same-origin (default for monolith deploy).
# Set to a full URL when frontend & backend are on different domains.
# Example: NEXT_PUBLIC_API_BASE_URL="https://api.prometheus.example.com"
# =====================================================
NEXT_PUBLIC_API_BASE_URL=""

# =====================================================
# Gateway rate limiting
# Per API key, per minute. Tighten in production based on your pool depth.
# =====================================================
GATEWAY_RPM="60"

# =====================================================
# Kiro pool auto-recovery cooldown
# How long (hours) to wait before re-probing an exhausted account.
# Kiro free tier resets daily, so 6h is a reasonable default - shorter
# wastes probes, longer leaves capacity stranded.
# =====================================================
KIRO_REVIVE_COOLDOWN_HOURS="6"
